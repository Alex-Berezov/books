datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// =====================
// Main entities
// =====================

model Book {
  id        String        @id @default(uuid())
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  versions  BookVersion[]
  ratings   BookRating[]
}

model BookVersion {
  id              String            @id @default(uuid())
  bookId          String
  language        Language
  title           String
  author          String
  description     String
  coverImageUrl   String
  type            BookType
  isFree          Boolean
  referralUrl     String?
  slug            String?
  // Publication
  status          PublicationStatus @default(published)
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  book            Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  summaries       BookSummary[]
  chapters        Chapter[]
  audioChapters   AudioChapter[]
  bookshelf       Bookshelf[]
  comments        Comment[]
  likes           Like[]
  categories      BookCategory[]
  tags            BookTag[]
  viewStats       ViewStat[]
  readingProgress ReadingProgress[]
  seo             Seo?              @relation("SeoForBookVersion", fields: [seoId], references: [id])
  seoId           Int?              @unique
  previewMedia    MediaAsset?       @relation("VersionPreviewMedia", fields: [previewMediaId], references: [id], onDelete: SetNull)
  previewMediaId  String?
  primaryCategoryId String?
  primaryCategory   Category?       @relation("BookVersionPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  firstPublishedYear    Int?
  editionPublishedYear  Int?
  originalLanguage      String?
  copyrightStatus       String?
  authorPageUrl         String?
  authorId              String?
  authorRelation        Author?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  characters            Json?
  quotes                Json?
  faq                   Json?
  themes                Json?
  originalTitle         String?
  alternativeTitles     Json?
  shortDescription      String?
  summaryShort          String?
  symbols               Json?
  coverAlt              String?

  @@unique([bookId, language])
  @@unique([language, slug])
  @@index([bookId, language, type, isFree], name: "book_language_type_isFree_idx")
  @@index([previewMediaId])
  @@index([primaryCategoryId])
  @@index([authorId])
}

model BookSummary {
  id            String      @id @default(uuid())
  bookVersionId String
  summary       String
  analysis      String?
  themes        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
}

model Chapter {
  id            String      @id @default(uuid())
  bookVersionId String
  number        Int
  title         String
  content       String
  createdAt     DateTime    @default(now())
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  comments      Comment[]

  @@unique([bookVersionId, number])
}

model AudioChapter {
  id            String      @id @default(uuid())
  bookVersionId String
  number        Int
  title         String
  audioUrl      String
  duration      Int
  description   String?
  transcript    String?
  mediaId       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  media         MediaAsset? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  comments      Comment[]

  @@unique([bookVersionId, number])
  @@index([mediaId])
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  passwordHash       String?
  name               String?
  firstName          String?
  lastName           String?
  nickname           String?           @unique
  isActive           Boolean           @default(true)
  avatarUrl          String?
  languagePreference Language
  createdAt          DateTime          @default(now())
  lastLogin          DateTime?
  bookshelves        Bookshelf[]
  comments           Comment[]
  likes              Like[]
  viewStats          ViewStat[]
  readingProgress    ReadingProgress[]
  roles              UserRole[]
  mediaAssets        MediaAsset[]
  ratings            BookRating[]
  rightsIntakes      RightsIntake[]
}



model Bookshelf {
  id            String      @id @default(uuid())
  userId        String
  bookVersionId String
  addedAt       DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, bookVersionId])
}

model Comment {
  id             String        @id @default(uuid())
  userId         String
  bookVersionId  String?
  chapterId      String?
  audioChapterId String?
  parentId       String?
  ratingId       String?       @unique
  text           String
  isDeleted      Boolean       @default(false)
  isHidden       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  bookVersion    BookVersion?  @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  chapter        Chapter?      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  audioChapter   AudioChapter? @relation(fields: [audioChapterId], references: [id], onDelete: Cascade)
  rating         BookRating?   @relation(fields: [ratingId], references: [id], onDelete: SetNull)
  parent         Comment?      @relation("CommentParent", fields: [parentId], references: [id])
  children       Comment[]     @relation("CommentParent")
  likes          Like[]

  @@index([bookVersionId])
  @@index([chapterId])
  @@index([audioChapterId])
  @@index([parentId])
}

model Like {
  id            String       @id @default(uuid())
  userId        String
  bookVersionId String? // FK to BookVersion
  commentId     String? // FK to Comment
  isLike        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id])
  bookVersion   BookVersion? @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  comment       Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@unique([userId, bookVersionId])
  @@index([commentId])
  @@index([bookVersionId])
}

model Category {
  id          String         @id @default(uuid())
  type        CategoryType
  name        String
  slug        String
  key         String         @unique
  indexable   Boolean        @default(true)
  isVisible   Boolean        @default(true)
  sortOrder   Int            @default(0)
  books       BookCategory[]
  // Category hierarchy (self-relation)
  parentId    String?
  parent      Category?       @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[]      @relation("CategoryToCategory")
  translations CategoryTranslation[]
  primaryCategoryVersions BookVersion[] @relation("BookVersionPrimaryCategory")

  @@index([parentId])
}

model BookCategory {
  id            String      @id @default(uuid())
  bookVersionId String
  categoryId    String
  isPrimary     Boolean     @default(false)
  sortOrder     Int         @default(0)
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  category      Category    @relation(fields: [categoryId], references: [id])

  @@unique([bookVersionId, categoryId])
  @@index([bookVersionId])
  @@index([categoryId])
}

model Tag {
  id        String    @id @default(uuid())
  name      String
  slug      String
  key       String    @unique
  indexable Boolean   @default(true)
  isVisible Boolean   @default(true)
  sortOrder Int       @default(0)
  books     BookTag[]
  translations TagTranslation[]
}

model BookTag {
  id            String      @id @default(uuid())
  bookVersionId String
  tagId         String
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id])

  @@unique([bookVersionId, tagId])
  @@index([tagId])
  @@index([bookVersionId])
}

model ViewStat {
  id            String      @id @default(uuid())
  bookVersionId String
  userId        String?
  source        ViewSource
  timestamp     DateTime    @default(now())
  bookVersion   BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@index([bookVersionId, timestamp])
  @@index([userId])
}

model ReadingProgress {
  id                 String      @id @default(uuid())
  userId             String
  bookVersionId      String
  chapterNumber      Int?
  audioChapterNumber Int?
  position           Float
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id])
  bookVersion        BookVersion @relation(fields: [bookVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, bookVersionId])
}

// =====================
// Media Library
// =====================

model MediaAsset {
  id           String   @id @default(uuid())
  key          String   @unique
  url          String
  contentType  String?
  size         Int?
  width        Int?
  height       Int?
  duration     Int?
  hash         String?
  createdAt    DateTime @default(now())
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  audioChapters AudioChapter[]
  previewVersions BookVersion[] @relation("VersionPreviewMedia")

  @@index([createdAt])
  @@index([hash])
  @@index([isDeleted, deletedAt])
}

// =====================
// CMS Pages
// =====================

model Page {
  id               String      @id @default(uuid())
  slug             String
  title            String
  type             PageType
  content          String
  status           PublicationStatus @default(draft)
  language         Language
  translationGroupId String? @map("translation_group_id") @db.Uuid

  // SEO content fields
  h1               String?
  shortDescription String?   @db.Text
  faq              Json?

  // Homepage-specific sections data (JSON)
  sections         Json?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  // Optional SEO one-to-one
  seo              Seo?       @relation("SeoForPage", fields: [seoId], references: [id])
  seoId            Int?       @unique

  @@unique([language, slug])
  @@index([language])
  @@index([translationGroupId])
}

// =====================
// SEO model
// =====================

model Seo {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === Main meta tags ===
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  robots          String?

  // === Open Graph ===
  ogTitle       String?
  ogDescription String?
  ogType        String?
  ogUrl         String?
  ogImageUrl    String?
  ogImageAlt    String?

  // === Twitter Card ===
  twitterCard    String?
  twitterSite    String?
  twitterCreator String?

  // === Event markup (schema.org/Event) ===
  eventName            String?
  eventDescription     String?
  eventStartDate       DateTime?
  eventEndDate         DateTime?
  eventUrl             String?
  eventImageUrl        String?
  eventLocationName    String?
  eventLocationStreet  String?
  eventLocationCity    String?
  eventLocationRegion  String?
  eventLocationPostal  String?
  eventLocationCountry String?

  // Relation to BookVersion (1:1)
  bookVersion BookVersion? @relation("SeoForBookVersion")

  // Relation to Page (1:1)
  page Page? @relation("SeoForPage")

  // Relation to CategoryTranslation (1:1)
  categoryTranslation CategoryTranslation? @relation("SeoForCategoryTranslation")

  // Relation to TagTranslation (1:1)
  tagTranslation TagTranslation? @relation("SeoForTagTranslation")

  // Relation to AuthorTranslation (1:1)
  authorTranslation AuthorTranslation? @relation("SeoForAuthorTranslation")
}

model Author {
  id            String              @id @default(uuid())
  birthDate     String?             // Формат YYYY-MM-DD
  deathDate     String?             // Формат YYYY-MM-DD
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  
  translations  AuthorTranslation[]
  bookVersions  BookVersion[]
}

model AuthorTranslation {
  id            String   @id @default(uuid())
  authorId      String
  language      Language
  slug          String
  name          String
  biography     String?  @db.Text
  wikidataUrl   String?
  wikipediaUrl  String?
  photoUrl      String?
  quotes        Json?    // Массив цитат: [{ text: "...", source: "..." }]
  faq           Json?    // Массив вопросов и ответов: [{ question: "...", answer: "..." }]
  similarSlugs  Json?    // Массив слагов похожих авторов: ["oscar-wilde", ...]

  seoId         Int?     @unique
  seo           Seo?     @relation("SeoForAuthorTranslation", fields: [seoId], references: [id], onDelete: SetNull)

  author        Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, language])
  @@unique([language, slug])
}

// =====================
// ENUMS
// =====================

enum Language {
  en
  es
  fr
  pt
  ru
}

enum BookType {
  text
  audio
  referral
}

enum LikeTarget {
  comment
  bookVersion
}

enum CategoryType {
  category
  genre
  collection
}

enum ViewSource {
  text
  audio
  referral
}

// CMS page types
enum PageType {
  generic
  category_index
  author_index
  homepage
}

// =====================
// Taxonomy Translations
// =====================

model CategoryTranslation {
  id               String   @id @default(uuid())
  categoryId       String
  language         Language
  name             String
  slug             String
  description      String?  @db.Text

  // SEO fields
  h1               String?
  shortDescription String?  @db.Text
  metaTitle        String?
  metaDescription  String?  @db.Text
  ogTitle          String?
  ogDescription    String?  @db.Text
  ogImageUrl       String?
  ogImageAlt       String?
  faq              Json?

  seoId            Int?     @unique
  seo              Seo?     @relation("SeoForCategoryTranslation", fields: [seoId], references: [id], onDelete: SetNull)
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([language, slug])
  @@unique([categoryId, language])
  @@index([categoryId])
  @@index([language])
}

model TagTranslation {
  id               String   @id @default(uuid())
  tagId            String
  language         Language
  name             String
  slug             String
  description      String?  @db.Text
  h1               String?
  shortDescription String?  @db.Text
  metaTitle        String?
  metaDescription  String?  @db.Text
  ogTitle          String?
  ogDescription    String?  @db.Text
  ogImageUrl       String?
  ogImageAlt       String?
  canonicalUrl     String?
  robots           String?  @default("index, follow")
  indexable        Boolean  @default(true)
  faq              Json?    // [{question: string, answer: string}]
  relatedTagSlugs  Json?    // string[]
  relatedGenreSlugs Json?   // string[]
  relatedCategorySlugs Json?   // string[]
  relatedCollectionSlugs Json? // string[]
  seoId            Int?     @unique
  seo              Seo?     @relation("SeoForTagTranslation", fields: [seoId], references: [id], onDelete: SetNull)
  tag              Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([language, slug])
  @@unique([tagId, language])
  @@index([tagId])
  @@index([language])
}

// =====================
// Rights Intake (Phase 1)
// =====================

model RightsIntake {
  id String @id @default(uuid())

  candidateTitle   String
  candidateAuthor  String
  originalTitle    String?
  originalLanguage String?
  authorBirthYear  Int?
  authorDeathYear  Int?

  sourceProvider   RightsSourceProvider   @default(UNKNOWN)
  sourceExternalId String?
  sourceUrl        String?
  sourceTitle      String?
  sourceLanguage   String?
  sourceTextType   RightsSourceTextType @default(UNKNOWN)

  targetLanguages     Json
  targetCountryCodes  Json
  plannedContentTypes Json
  plannedComponents   Json?

  notesRu        String?
  workflowStatus RightsIntakeStatus @default(DRAFT)

  createdByUserId String?
  createdByUser   User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  approvedReviewId String?
  createdBookId    String?
  archivedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowStatus])
  @@index([createdAt])
  @@index([createdByUserId])
}

enum RightsIntakeStatus {
  DRAFT
  READY_FOR_AGENT
  REVIEW_IMPORTED
  HUMAN_REVIEW_REQUIRED
  APPROVED
  REJECTED
  BOOK_CREATED
  ARCHIVED
}

enum RightsSourceProvider {
  PROJECT_GUTENBERG
  OTHER
  UNKNOWN
}

enum RightsSourceTextType {
  ORIGINAL_TEXT
  TRANSLATION
  ADAPTATION
  ABRIDGMENT
  COMPILATION
  UNKNOWN
}

// =====================
// Roles & Permissions
// =====================

model Role {
  id    Int        @id @default(autoincrement())
  name  RoleName   @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

enum RoleName {
  user
  admin
  content_manager
}

// =====================
// Publication Status
// =====================

enum PublicationStatus {
  draft
  published
}

model BookRating {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  score     Int      // Score from 1 to 5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  comment   Comment?

  @@unique([userId, bookId])
  @@index([bookId])
}
